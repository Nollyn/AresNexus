{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Graphics --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "TPS (Transactions Per Second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settlement_total_count[1m]))",
          "legendFormat": "Settlement Throughput"
        }
      ]
    },
    {
      "title": "Success Rate",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(settlement_total_count{status=\"success\"}[1m])) / sum(rate(settlement_total_count[1m]))",
          "legendFormat": "Success Heatmap"
        }
      ]
    },
    {
      "title": "Regional Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "up{region=~\"switzerland.*\"}",
          "legendFormat": "{{region}}"
        }
      ]
    },
    {
      "title": "Audit Lag (FINMA Compliance)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "values": true,
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "max(settlement_processing_seconds_sum / settlement_processing_seconds_count)",
          "legendFormat": "Avg Persistence Lag"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
