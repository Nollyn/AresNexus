from fastapi import FastAPI, Response
from pydantic import BaseModel

app = FastAPI(title="Ares-Nexus Compliance Engine", version="1.0.0")

class Transaction(BaseModel):
    accountId: str
    amount: float
    type: str

@app.post("/validate")
def validate(tx: Transaction):
    # Simulate validation logic
    if tx.amount > 1000000:
        return {"status": "REJECTED", "reason": "Tier-1 transaction requires manual audit"}
    return {"status": "APPROVED", "riskScore": 0.01}

@app.get("/metrics")
def metrics():
    # Simple OpenMetrics/Prometheus implementation without prometheus_client library
    return Response(
        content="# HELP compliance_validation_errors_total Total number of compliance validation errors\n# TYPE compliance_validation_errors_total counter\ncompliance_validation_errors_total 0\n",
        media_type="text/plain; version=0.0.4; charset=utf-8"
    )

@app.get("/health")
def health():
    return {"status": "UP"}
